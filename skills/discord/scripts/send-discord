#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["httpx"]
# ///
"""
send-discord - Send a message (with optional attachments) to a Discord channel

Usage:
    send-discord <channel_id> <message>
    send-discord <channel_id> <message> --image /path/to/image.png
    send-discord <channel_id> <message> --file /path/to/file.pdf
    send-discord <channel_id> --image /path/to/image.png   # Image only
"""
import sys
import os
import subprocess
import argparse
import mimetypes
from pathlib import Path
import httpx

DISCORD_API = "https://discord.com/api/v10"


def get_token() -> str:
    """Get Discord bot token from keychain (primary), then env var, then secrets file."""
    try:
        result = subprocess.run(
            ["security", "find-generic-password", "-s", "discord_bot_token", "-w"],
            capture_output=True, text=True
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
    except Exception:
        pass

    token = os.environ.get("DISCORD_BOT_TOKEN")
    if token:
        return token

    secrets_path = os.path.expanduser("~/.claude/secrets.env")
    if os.path.exists(secrets_path):
        for line in open(secrets_path):
            if line.startswith("DISCORD_BOT_TOKEN="):
                return line.strip().split("=", 1)[1].strip('"').strip("'")

    print("Error: DISCORD_BOT_TOKEN not found in keychain, env, or secrets", file=sys.stderr)
    sys.exit(1)


def split_message(message: str, limit: int = 2000) -> list[str]:
    """Split message into chunks respecting Discord's 2000 char limit."""
    chunks = []
    while message:
        if len(message) <= limit:
            chunks.append(message)
            break
        split_at = message.rfind("\n", 0, limit)
        if split_at == -1:
            split_at = message.rfind(" ", 0, limit)
        if split_at == -1:
            split_at = limit
        chunks.append(message[:split_at])
        message = message[split_at:].lstrip()
    return chunks


def send_with_attachment(channel_id: str, token: str, message: str, file_path: str):
    """Send a message with a file attachment using multipart form data."""
    path = Path(file_path)
    if not path.exists():
        print(f"Error: File not found: {file_path}", file=sys.stderr)
        sys.exit(1)

    mime_type = mimetypes.guess_type(str(path))[0] or "application/octet-stream"
    headers = {"Authorization": f"Bot {token}"}

    trigger_typing(channel_id, token)

    with open(path, "rb") as f:
        files = {"file": (path.name, f, mime_type)}
        data = {}
        if message:
            data["content"] = message

        resp = httpx.post(
            f"{DISCORD_API}/channels/{channel_id}/messages",
            headers=headers,
            files=files,
            data=data,
            timeout=120.0,
        )

    if resp.status_code == 429:
        import time
        retry_after = resp.json().get("retry_after", 1)
        time.sleep(retry_after)
        with open(path, "rb") as f:
            files = {"file": (path.name, f, mime_type)}
            resp = httpx.post(
                f"{DISCORD_API}/channels/{channel_id}/messages",
                headers=headers,
                files=files,
                data=data,
                timeout=120.0,
            )

    if resp.status_code not in (200, 201):
        print(f"Error: {resp.status_code} {resp.text}", file=sys.stderr)
        sys.exit(1)

    print("OK")



def trigger_typing(channel_id: str, token: str):
    """Send typing indicator to show the bot is typing."""
    try:
        httpx.post(
            f"{DISCORD_API}/channels/{channel_id}/typing",
            headers={"Authorization": f"Bot {token}"},
            timeout=5.0,
        )
    except Exception:
        pass  # Non-critical, don't fail the message send


def send_text(channel_id: str, token: str, message: str):
    """Send a text-only message (split into chunks if needed)."""
    headers = {
        "Authorization": f"Bot {token}",
        "Content-Type": "application/json",
    }

    trigger_typing(channel_id, token)

    for chunk in split_message(message):
        resp = httpx.post(
            f"{DISCORD_API}/channels/{channel_id}/messages",
            headers=headers,
            json={"content": chunk},
        )
        if resp.status_code == 429:
            import time
            retry_after = resp.json().get("retry_after", 1)
            time.sleep(retry_after)
            resp = httpx.post(
                f"{DISCORD_API}/channels/{channel_id}/messages",
                headers=headers,
                json={"content": chunk},
            )
        if resp.status_code not in (200, 201):
            print(f"Error: {resp.status_code} {resp.text}", file=sys.stderr)
            sys.exit(1)

    print("OK")


def main():
    parser = argparse.ArgumentParser(description="Send a message to a Discord channel")
    parser.add_argument("channel_id", help="Discord channel ID")
    parser.add_argument("message", nargs="?", default="", help="Message text")
    parser.add_argument("--image", "-i", help="Path to image file to attach")
    parser.add_argument("--file", "-f", help="Path to any file to attach")
    args = parser.parse_args()

    if not args.message and not args.image and not args.file:
        parser.error("Must provide message, --image, or --file")

    message = args.message.replace("\\!", "!") if args.message else ""
    token = get_token()

    attachment = args.image or args.file
    if attachment:
        send_with_attachment(args.channel_id, token, message, attachment)
    else:
        send_text(args.channel_id, token, message)


if __name__ == "__main__":
    main()
