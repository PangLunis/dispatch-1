#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["requests"]
# ///
"""Look up movie/TV show info from TMDB and display a formatted card."""

import argparse
import subprocess
import sys

import requests

TMDB_BASE = "https://api.themoviedb.org/3"
IMDB_TITLE_URL = "https://www.imdb.com/title"


def get_api_key() -> str:
    """Retrieve TMDB API key from macOS Keychain."""
    try:
        result = subprocess.run(
            ["security", "find-generic-password", "-s", "tmdb", "-a", "api_key", "-w"],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError:
        print("Error: TMDB API key not found in keychain.", file=sys.stderr)
        print("Add it with: security add-generic-password -s tmdb -a api_key -w YOUR_KEY", file=sys.stderr)
        sys.exit(1)


def search_multi(api_key: str, query: str) -> dict | None:
    """Search TMDB for a movie or TV show by title."""
    resp = requests.get(
        f"{TMDB_BASE}/search/multi",
        params={"api_key": api_key, "query": query, "include_adult": "false"},
        timeout=10,
    )
    resp.raise_for_status()
    results = resp.json().get("results", [])
    # Filter to movie/tv only, pick first
    for item in results:
        if item.get("media_type") in ("movie", "tv"):
            return item
    return None


def fetch_details(api_key: str, media_type: str, tmdb_id: int) -> dict:
    """Fetch full details with credits and external IDs."""
    resp = requests.get(
        f"{TMDB_BASE}/{media_type}/{tmdb_id}",
        params={"api_key": api_key, "append_to_response": "credits,external_ids"},
        timeout=10,
    )
    resp.raise_for_status()
    return resp.json()


def extract_info(details: dict, media_type: str) -> dict:
    """Extract relevant fields from TMDB detail response."""
    info: dict = {}

    if media_type == "movie":
        info["title"] = details.get("title", "Unknown")
        release = details.get("release_date", "")
        info["year"] = release[:4] if release else "N/A"
        runtime = details.get("runtime")
        info["runtime"] = f"{runtime} min" if runtime else "N/A"
        # Director from crew
        crew = details.get("credits", {}).get("crew", [])
        directors = [p["name"] for p in crew if p.get("job") == "Director"]
        info["director_label"] = "Director"
        info["director"] = ", ".join(directors) if directors else "N/A"
    else:
        info["title"] = details.get("name", "Unknown")
        first_air = details.get("first_air_date", "")
        info["year"] = first_air[:4] if first_air else "N/A"
        runtimes = details.get("episode_run_time", [])
        if runtimes:
            info["runtime"] = f"{runtimes[0]} min/ep"
        elif details.get("last_episode_to_air", {}).get("runtime"):
            info["runtime"] = f"{details['last_episode_to_air']['runtime']} min/ep"
        else:
            info["runtime"] = "N/A"
        creators = details.get("created_by", [])
        info["director_label"] = "Creator"
        info["director"] = ", ".join(c["name"] for c in creators) if creators else "N/A"

    # Ratings
    tmdb_rating = details.get("vote_average")
    info["tmdb_rating"] = f"{tmdb_rating:.1f}/10" if tmdb_rating else "N/A"

    # IMDb ID
    ext = details.get("external_ids", {})
    imdb_id = ext.get("imdb_id") or details.get("imdb_id")
    info["imdb_id"] = imdb_id
    info["imdb_url"] = f"{IMDB_TITLE_URL}/{imdb_id}/" if imdb_id else None

    # Cast (top 3)
    cast = details.get("credits", {}).get("cast", [])
    info["cast"] = [a["name"] for a in cast[:3]]

    # Genres
    genres = details.get("genres", [])
    info["genres"] = [g["name"] for g in genres]

    # Status for TV
    if media_type == "tv":
        info["status"] = details.get("status", "")
        info["seasons"] = details.get("number_of_seasons")

    info["media_type"] = media_type
    return info


def format_discord(info: dict) -> str:
    """Format as Discord-style markdown."""
    media_label = "Movie" if info["media_type"] == "movie" else "TV Show"
    lines = [
        f"**{info['title']}** ({info['year']}) — {media_label}",
        "",
        f"**TMDB Rating:** {info['tmdb_rating']}",
        f"**{info['director_label']}:** {info['director']}",
        f"**Cast:** {', '.join(info['cast']) if info['cast'] else 'N/A'}",
        f"**Genres:** {', '.join(info['genres']) if info['genres'] else 'N/A'}",
        f"**Runtime:** {info['runtime']}",
    ]
    if info["media_type"] == "tv":
        seasons = info.get("seasons")
        status = info.get("status", "")
        if seasons:
            lines.append(f"**Seasons:** {seasons} ({status})")
    if info["imdb_url"]:
        lines.append(f"**IMDb:** {info['imdb_url']}")
    return "\n".join(lines)


def format_sms(info: dict) -> str:
    """Format as compact plain text for SMS."""
    media_label = "Movie" if info["media_type"] == "movie" else "TV"
    parts = [
        f"{info['title']} ({info['year']}) [{media_label}]",
        f"TMDB: {info['tmdb_rating']}",
        f"{info['director_label']}: {info['director']}",
        f"Cast: {', '.join(info['cast']) if info['cast'] else 'N/A'}",
        f"Genres: {', '.join(info['genres']) if info['genres'] else 'N/A'}",
        f"Runtime: {info['runtime']}",
    ]
    if info["media_type"] == "tv":
        seasons = info.get("seasons")
        status = info.get("status", "")
        if seasons:
            parts.append(f"Seasons: {seasons} ({status})")
    if info["imdb_url"]:
        parts.append(info["imdb_url"])
    return "\n".join(parts)


def main() -> None:
    parser = argparse.ArgumentParser(description="Look up movie/TV info from TMDB")
    parser.add_argument("query", help="Movie or TV show title to search for")
    parser.add_argument(
        "--format",
        choices=["discord", "sms"],
        default="discord",
        dest="fmt",
        help="Output format (default: discord)",
    )
    args = parser.parse_args()

    api_key = get_api_key()

    result = search_multi(api_key, args.query)
    if not result:
        print(f"No movie or TV show found for: {args.query}", file=sys.stderr)
        sys.exit(1)

    media_type = result["media_type"]
    tmdb_id = result["id"]

    details = fetch_details(api_key, media_type, tmdb_id)
    info = extract_info(details, media_type)

    if args.fmt == "discord":
        print(format_discord(info))
    else:
        print(format_sms(info))


if __name__ == "__main__":
    main()
